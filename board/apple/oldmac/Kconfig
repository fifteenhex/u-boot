if TARGET_OLDMAC

config SYS_BOARD
	default "oldmac"

config SYS_VENDOR
	default "apple"

config SYS_CONFIG_NAME
	default "oldmac"

config CMD_NUBUS
	bool "nubus command"
	default y
	help
	  Enable the "nubus" command, which probes the NuBus slots and lists
	  the cards found by reading their declaration ROMs.

endif
