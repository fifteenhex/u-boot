/dts-v1/;
#include "mc68030.dtsi"
/ {
	#address-cells = <1>;
	#size-cells = <1>;

	compatible = "motorola,mvme147";

	aliases {
		serial0 = &uart0;
	};

	chosen {
		stdout-path = "/serial@fffe3002:9600";
		//tick-timer = &timer;
	};

	memory {
		device_type = "memory";
		reg = <0x0 0x4000000>;
	};

		uart0: serial@fffe3002 {
			compatible = "zilog,scc";
			u-boot,dm-pre-reloc;
			reg = <0xfffe3002 0x2>;
			status = "okay";
		};


        soc {
                compatible = "simple-bus";
                #address-cells = <1>;
                #size-cells = <1>;

	};
};
